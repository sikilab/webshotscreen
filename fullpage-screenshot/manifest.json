{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "1.0.30",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/scissor-crop-16.png",
    "32": "icons/scissor-crop-32.png",
    "48": "icons/scissor-crop-48.png",
    "128": "icons/scissor-crop-128.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/scissor-crop-16.png",
      "32": "icons/scissor-crop-32.png",
      "48": "icons/scissor-crop-48.png",
      "128": "icons/scissor-crop-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "__MSG_appName__"
  },
  "default_locale": "zh_CN"
}
